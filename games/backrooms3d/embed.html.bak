  // mobile joystick
  const joyBase=$("joyBase"), joyKnob=$("joyKnob");
  let joyActive=false, joyCx=0, joyCy=0;
  let joyX=0, joyY=0;
  function setJoy(vx,vy){ joyX=vx; joyY=vy; }
  function joyStart(x,y){
    if(x>innerWidth*0.55) return;
    joyActive=true; joyCx=x; joyCy=y;
    joyBase.style.display="block";
    joyBase.style.left=(joyCx-joyBase.offsetWidth/2)+"px";
    joyBase.style.top =(joyCy-joyBase.offsetHeight/2)+"px";
    joyKnob.style.left="50%"; joyKnob.style.top="50%";
  }
  function joyMove(x,y){
    if(!joyActive) return;
    const dx=x-joyCx, dy=y-joyCy;
    const max=42;
    const nx=Math.max(-max, Math.min(max, dx));
    const ny=Math.max(-max, Math.min(max, dy));
    joyKnob.style.left=(50+(nx/max)*30)+"%";
    joyKnob.style.top =(50+(ny/max)*30)+"%";
    setJoy(nx/max, ny/max);
  }
  function joyEnd(){
    if(!joyActive) return;
    joyActive=false; joyBase.style.display="none"; setJoy(0,0);
  }
  addEventListener("touchstart",(e)=>{ if(e.touches.length===1){ const t=e.touches[0]; joyStart(t.clientX,t.clientY);} }, {passive:true});
  addEventListener("touchmove",(e)=>{ if(joyActive && e.touches.length===1){ const t=e.touches[0]; joyMove(t.clientX,t.clientY); e.preventDefault();} }, {passive:false});
  addEventListener("touchend", joyEnd, {passive:true});
  addEventListener("touchcancel", joyEnd, {passive:true});

    
  function nearestObj(arr, maxDist){
    let best=null, bd=maxDist;
    for(const o of arr){
      const dx=o.position.x-player.position.x;
      const dz=o.position.z-player.position.z;
      const d=Math.hypot(dx,dz);
    const nowMs = performance.now();

    // Monster can also pick up carrots: 5s movement speed buff
    for(let i=carrots.length-1;i>=0;i--){
      const c = carrots[i];
      const mdx = c.position.x - monster.position.x;
      const mdz = c.position.z - monster.position.z;
      if(mdx*mdx + mdz*mdz < 1.35*1.35){
        scene.remove(c);
        carrots.splice(i,1);
        monsterSpeedBuffUntil = performance.now() + 5000;
        addChat("🥕 [괴물] 5초간 이동속도 1.5배!");
        ensureCarrots();
        break;
      }
    }

      if(d<bd){ bd=d; best=o; }
    }
    return best;
  }
  function toppleNearestShelf(){
    const s=nearestObj(shelves, 2.7);
    if(!s || s.userData.fallen) return;
    s.userData.fallen=true; s.userData.fallT=0; s.userData.fellAt = performance.now(); s.userData.stunArmed = true; s.userData.cleared = false;
    // Update collider to match fallen footprint (standing -> lying).
    // Standing footprint: width=1.9, depth=0.75
    // Lying footprint (after falling forward/back): width=1.9, depth=3.9
    const yrot = (s.rotation.y||0)%(Math.PI*2);
    const swap = Math.abs(Math.sin(yrot))>0.5; // rotated 90deg in Y swaps X/Z in world
    const lieHX   = (0.95+0.05)*SHELF_SCALE;
    const lieHZ   = (1.95+0.08)*SHELF_SCALE; // half of 3.9 + margin
    const hx = swap ? lieHZ : lieHX;
    const hz = swap ? lieHX : lieHZ;
    s.userData.halfX = hx;
    s.userData.halfZ = hz;
    addChat("[싱글] 책장을 쓰러뜨렸다!");
  }
  function doInteract(){

    if(chatMode || document.activeElement===chatIn || $("mathModal").classList.contains("show")) return;
    if(rabbitGhost){
      addChat('유령 상태에서는 상호작용할 수 없습니다.');
      return;
    }
    // If trapped inside a locked cage, pressing E gives math problems to escape.
    try{
      if(playerInsideCage() && cage.userData.locked && !cage.userData.doorOpen){
        startCageEscapeMath();
        return;
      }
    }catch(e){}
    const k=nearestObj(keys, 2.1);
    if(k){
      if(rabbitGhost){ addChat('유령 상태에서는 열쇠를 들 수 없습니다.'); hidePrompt(); return; }
      scene.remove(k);
      keys.splice(keys.indexOf(k),1);
      keyCount = 1; beep(660,0.06,'sine',0.35); $("pKey").textContent="🔑 "+keyCount; updateKeyIndicator();
      addChat("["+playerName+"]가 열쇠를 먹었습니다.");
      hidePrompt(); return;
    }
    
    // Cage lock / door interaction
    const cDist=Math.hypot(cage.position.x-player.position.x, cage.position.z-player.position.z);
    if(cDist<3.0){
      const lock = cage.getObjectByName("cageLock");
      const hinge = cage.getObjectByName("cageHinge");
      if(cage.userData.locked){
        if(keyCount>=1){
          keyCount=Math.max(0,keyCount-1); $("pKey").textContent="🔑 "+keyCount; updateKeyIndicator();
          try{ placeKey(); }catch(e){}
          cage.userData.locked=false;
          if(playerInsideCage()) player.userData.trapped = false;
          // simple lock "open" animation (hide)
          if(lock) lock.visible=false;
          addChat("철창 자물쇠가 열렸다!");
        }else{
          addChat("자물쇠를 열려면 열쇠 1개가 필요합니다.");
        }
        hidePrompt(); return;
      }else{
        // toggle door
        cage.userData.doorOpen = cage.userData.doorOpen?0:1;
        if(cage.userData.doorOpen){
          cage.userData.autoCloseT = 5.0;
          setCageCountdown(cage.userData.autoCloseT);
          cageCdSprite.visible = true;
        }else{
          cage.userData.autoCloseT = 0;
          cageCdSprite.visible = false;
        }
        addChat(cage.userData.doorOpen? "철창이 열렸다!" : "철창이 닫혔다.");
        hidePrompt(); return;
      }
    }
    const dDist=Math.hypot(doorG.position.x-player.position.x, doorG.position.z-player.position.z);
    if(dDist<2.6){
      const sealLeft = Math.max(0, doorState.sealedUntil - performance.now());
      if(sealLeft>0){ addChat('🚫 탈출문이 봉인되어 있습니다! ('+Math.ceil(sealLeft/1000)+'초)'); return; }
      const locks = (doorG.userData && doorG.userData.locks) ? doorG.userData.locks : [];
      const unlocked = doorState.locksUnlocked;
      if(unlocked < 3){
        if(rabbitGhost){ addChat('유령 상태에서는 탈출문을 조작할 수 없습니다.'); return; }
        if(keyCount<=0){ addChat("[싱글] 자물쇠를 풀려면 열쇠가 필요하다."); return; }
        keyCount = 0; $("pKey").textContent="🔑 "+keyCount; updateKeyIndicator();
        try{ placeKey(); }catch(e){}
        const idx = Math.min(2, doorState.locksUnlocked);
        const lk = locks[idx];
        if(lk && lk.userData){ lk.userData.locked = false; lk.userData.t = 1.0; }
        doorState.locksUnlocked = Math.min(3, doorState.locksUnlocked + 1);
        doorProg = doorState.locksUnlocked;
        $("pDoor").textContent="문: "+doorProg+"/3";
        beep(520,0.08,'triangle',0.30);
        addChat("[싱글] 자물쇠가 풀렸다! ("+doorProg+"/3)");
        if(doorProg>=3) addChat("[싱글] 모든 자물쇠가 풀렸다. E로 문을 열고 탈출할 수 있다.");
        return;
      }
      if(!doorState.open){
        doorState.open = true;
        doorState.openT = 0;
        addChat("[싱글] 탈출문이 열린다!");
        beep(740,0.06,'sine',0.25);
      }else{
        addChat("✅ 탈출 성공(테스트)!");
        endGame("토끼 승리!");
      }
      return;
    }
    toppleNearestShelf();
  }
  function updatePrompt(){
    const k=nearestObj(keys, 2.1);
    if(k){ showPrompt("E: 열쇠 줍기"); return; }
    const dDist=Math.hypot(doorG.position.x-player.position.x, doorG.position.z-player.position.z);
    if(dDist<2.6){
      const sealLeft = Math.max(0, doorState.sealedUntil - performance.now());
      if(sealLeft>0) showPrompt("봉인됨: "+Math.ceil(sealLeft/1000)+"초");
      else if(doorState.locksUnlocked<3) showPrompt("E: 자물쇠 풀기 (열쇠 1개)  "+doorState.locksUnlocked+"/3");
      else if(!doorState.open) showPrompt("E: 문 열기");
      else showPrompt("E: 탈출(테스트)");
      return;
    }
    const cDist=Math.hypot(cage.position.x-player.position.x, cage.position.z-player.position.z);
    if(cDist<2.7){
      if(cage.userData && cage.userData.locked) showPrompt("E: 자물쇠 열기 (열쇠 1개)");
      else showPrompt("E: 철창 문 열기/닫기");
      return;
    }
    const s=nearestObj(shelves, 2.7);
    if(s && !s.userData.fallen){ showPrompt("E: 책장 쓰러뜨리기"); return; }
    hidePrompt();
    updateBtnELabel();

  }

  function isWallAt(x,z){
    const gx=Math.floor(x/CELL + GW/2);
    const gy=Math.floor(z/CELL + GH/2);
    if(gx<0||gy<0||gx>=GW||gy>=GH) return true;
    return grid[gy][gx]===1;
  }
  function hitAABB(px,pz, ox,oz, hx,hz, rad){
    const cx=Math.max(ox-hx, Math.min(px, ox+hx));
    const cz=Math.max(oz-hz, Math.min(pz, oz+hz));
    const dx=px-cx, dz=pz-cz;
    return (dx*dx + dz*dz) < rad*rad;
  }
  function pushOutFromAABB(px,pz, ox,oz, hx,hz, rad){
    const dx=px-ox, dz=pz-oz;
    const pxPen=(hx+rad)-Math.abs(dx);
    const pzPen=(hz+rad)-Math.abs(dz);
    if(pxPen<=0 || pzPen<=0) return {x:px,z:pz,pushed:false};
    if(pxPen<pzPen){
      const sx=Math.sign(dx)||1;
      return {x:px+sx*pxPen, z:pz, pushed:true};
    }else{
      const sz=Math.sign(dz)||1;
      return {x:px, z:pz+sz*pzPen, pushed:true};
    }
  }

  function hitCircle(px,pz, ox,oz, r, rad){
    const dx=px-ox, dz=pz-oz;
    const rr = r+rad;
    return (dx*dx+dz*dz) < rr*rr;
  }
  function pushOutFromCircle(px,pz, ox,oz, r, rad){
    let dx=px-ox, dz=pz-oz;
    const d=Math.hypot(dx,dz);
    const nowMs = performance.now();
    const rr=r+rad;
    if(d>=rr || d<1e-6) return {x:px,z:pz,pushed:false};
    const k=(rr-d)/d;
    return {x:px+dx*k, z:pz+dz*k, pushed:true};
  }
  function collidesProps(nx,nz, rad){
    for(const o of props){
      if(!o || !o.userData) continue;
      const kind=o.userData.kind;
      // Pushables (cart/ball) are allowed to overlap the player so they can be pushed.
      if(kind==="cart" || kind==="ball") continue;
      if(kind==="pillar"){ if(hitCircle(nx,nz,o.position.x,o.position.z,o.userData.halfX||0.6,rad)) return true; continue; }
      const hx=o.userData.halfX||0, hz=o.userData.halfZ||0;
      if(hitAABB(nx,nz,o.position.x,o.position.z,hx,hz,rad)) return true;
    }
    return false;
  }
  
function pushOutWalls(px,pz,rad){
  // Push-out against merged wall AABBs (more stable than per-cell sampling).
  let x=px, z=pz;
  for(let pass=0; pass<2; pass++){
    for(const b of wallBoxes){
      // cheap broadphase
      if(Math.abs(x-b.cx) > (b.hx + rad + CELL)) continue;
      if(Math.abs(z-b.cz) > (b.hz + rad + CELL)) continue;
      const po = pushOutFromAABB(x,z,b.cx,b.cz,b.hx,b.hz,rad);
      if(po.pushed){ x=po.x; z=po.z; }
    }
  }
  return {x,z};
}

  function resolveMove(nx,nz){
    const rad=0.60;

    // early accept
    const wallHit = collidesWalls(nx,nz,rad);
    if(!wallHit && !collidesProps(nx,nz,rad)) return {x:nx,z:nz};

    // axis-separated attempt
    let x=player.position.x, z=player.position.z;
    let tx=x, tz=z;

    // X move
    tx=nx;
    // apply wall pushout for candidate
    let p=pushOutWalls(tx,z,rad);
    tx=p.x; 
    // apply props pushout
    for(const o of props){
      if(!o || !o.userData) continue;
      const kind=o.userData.kind;
      if(kind==="cart" || kind==="ball") continue;
      const po=(o.userData.kind==="pillar")?pushOutFromCircle(tx,z,o.position.x,o.position.z,o.userData.halfX||0.6,rad):pushOutFromAABB(tx,z,o.position.x,o.position.z,o.userData.halfX,o.userData.halfZ,rad);
      if(po.pushed){ tx=po.x; z=po.z; }
    }
    // if still inside wall at sampling points, revert x
    if(!collidesWalls(tx,z,rad)) x=tx;

    // Z move
    tz=nz;
    p=pushOutWalls(x,tz,rad);
    tz=p.z;
    for(const o of props){
      if(!o || !o.userData) continue;
      const kind=o.userData.kind;
      if(kind==="cart" || kind==="ball") continue;
      const po=(o.userData.kind==="pillar")?pushOutFromCircle(x,tz,o.position.x,o.position.z,o.userData.halfX||0.6,rad):pushOutFromAABB(x,tz,o.position.x,o.position.z,o.userData.halfX,o.userData.halfZ,rad);
      if(po.pushed){ x=po.x; tz=po.z; }
    }
    if(!collidesWalls(x,tz,rad)) z=tz;

    // final depenetration pass (walls then props)
    p=pushOutWalls(x,z,rad);
    x=p.x; z=p.z;
    for(let k=0;k<2;k++){
      for(const o of props){
        if(!o || !o.userData) continue;
        const po=pushOutFromAABB(x,z,o.position.x,o.position.z,o.userData.halfX,o.userData.halfZ,rad);
        if(po.pushed){ x=po.x; z=po.z; }
      }
      p=pushOutWalls(x,z,rad);
      x=p.x; z=p.z;
    }
    return {x,z};
  }


  // Resolve movement for an arbitrary entity (used for monster too),
  // matching player collision behavior (walls + props + push-out).
  function resolveMoveAt(posX,posZ,nx,nz,rad){
    // early accept
    const wallHit = collidesWalls(nx,nz,rad);
    if(!wallHit && !collidesProps(nx,nz,rad)) return {x:nx,z:nz};

    let x=posX, z=posZ;
    let tx=x, tz=z;

    // X move
    tx=nx;
    let p=pushOutWalls(tx,z,rad);
    tx=p.x;
    for(const o of props){
      if(!o || !o.userData) continue;
      const kind=o.userData.kind;
      if(kind==="cart" || kind==="ball") continue;
      const po=(kind==="pillar")?pushOutFromCircle(tx,z,o.position.x,o.position.z,o.userData.halfX||0.6,rad)
                               :pushOutFromAABB(tx,z,o.position.x,o.position.z,o.userData.halfX,o.userData.halfZ,rad);
      if(po.pushed){ tx=po.x; z=po.z; }
    }
    if(!collidesWalls(tx,z,rad)) x=tx;

    // Z move
    tz=nz;
    p=pushOutWalls(x,tz,rad);
    tz=p.z;
    for(const o of props){
      if(!o || !o.userData) continue;
      const kind=o.userData.kind;
      if(kind==="cart" || kind==="ball") continue;
      const po=(kind==="pillar")?pushOutFromCircle(x,tz,o.position.x,o.position.z,o.userData.halfX||0.6,rad)
                               :pushOutFromAABB(x,tz,o.position.x,o.position.z,o.userData.halfX,o.userData.halfZ,rad);
      if(po.pushed){ x=po.x; tz=po.z; }
    }
    if(!collidesWalls(x,tz,rad)) z=tz;

    // final depenetration pass (walls then props)
    p=pushOutWalls(x,z,rad);
    x=p.x; z=p.z;
    for(let k=0;k<2;k++){
      for(const o of props){
        if(!o || !o.userData) continue;
        const kind=o.userData.kind;
        if(kind==="cart" || kind==="ball") continue;
        const po=(kind==="pillar")?pushOutFromCircle(x,z,o.position.x,o.position.z,o.userData.halfX||0.6,rad)
                                 :pushOutFromAABB(x,z,o.position.x,o.position.z,o.userData.halfX,o.userData.halfZ,rad);
        if(po.pushed){ x=po.x; z=po.z; }
      }
      p=pushOutWalls(x,z,rad);
      x=p.x; z=p.z;
    }
    return {x,z};
  }

  function updatePushables(dt){
    // Carts and balls are pushable. They should NOT block the player (handled in resolveMove),
    // but they must not tunnel into walls or solid props.
    const solidProps = (o)=> o && o.userData && (o.userData.kind!=="cart" && o.userData.kind!=="ball");
    for(const c of carts){
      c.userData.vx *= Math.pow(0.06, dt);
      c.userData.vz *= Math.pow(0.06, dt);
      let nx = c.position.x + (c.userData.vx||0)*dt;
      let nz = c.position.z + (c.userData.vz||0)*dt;

      // collide with walls using circle radius approximated from AABB
      const rad = Math.min(c.userData.halfX||0.7, c.userData.halfZ||0.6) * 0.95;
      // depenetrate against wall cells
      let p = pushOutWalls(nx, nz, rad);
      nx = p.x; nz = p.z;

      // depenetrate against solid props
      for(const o of props){
        if(!solidProps(o)) continue;
        const po = pushOutFromAABB(nx, nz, o.position.x, o.position.z, o.userData.halfX, o.userData.halfZ, rad);
        if(po.pushed){
          // damp velocity along the axis we were pushed
          if(Math.abs(po.x-nx) > Math.abs(po.z-nz)) c.userData.vx *= 0.25;
          else c.userData.vz *= 0.25;
          nx = po.x; nz = po.z;
        }
      }
      c.position.x = nx;
      c.position.z = nz;
    }

    for(const b of balls){
      b.userData.vx *= Math.pow(0.03, dt);
      b.userData.vz *= Math.pow(0.03, dt);
      let nx = b.position.x + (b.userData.vx||0)*dt;
      let nz = b.position.z + (b.userData.vz||0)*dt;
      b.rotation.x += (b.userData.vz||0)*dt*0.6;
      b.rotation.z -= (b.userData.vx||0)*dt*0.6;

      const rad = (b.userData.r||0.85);
      let p = pushOutWalls(nx, nz, rad);
      nx = p.x; nz = p.z;
      for(const o of props){
        if(!solidProps(o)) continue;
        const po = pushOutFromAABB(nx, nz, o.position.x, o.position.z, o.userData.halfX, o.userData.halfZ, rad);
        if(po.pushed){
          if(Math.abs(po.x-nx) > Math.abs(po.z-nz)) b.userData.vx *= 0.25;
          else b.userData.vz *= 0.25;
          nx = po.x; nz = po.z;
        }
      }
      b.position.x = nx;
      b.position.z = nz;
    }
  }
  function handlePush(dt){
    for(const c of carts){
      const dx=c.position.x-player.position.x;
      const dz=c.position.z-player.position.z;
      const d=Math.hypot(dx,dz);
    const nowMs = performance.now();
      if(d<1.35){
        const px=dx/(d||1), pz=dz/(d||1);
        c.userData.vx += px*16;
        c.userData.vz += pz*16;
      }
    }
    for(const b of balls){
      const dx=b.position.x-player.position.x;
      const dz=b.position.z-player.position.z;
      const d=Math.hypot(dx,dz);
    const nowMs = performance.now();
      if(d < (b.userData.r + 0.85)){
        const px=dx/(d||1), pz=dz/(d||1);
        b.userData.vx += px*18;
        b.userData.vz += pz*18;
      }
    }
  }
  function updateShelves(dt){
    for(const s of shelves){
      if(!s.userData.fallen) continue;
      if(s.userData.fallT>=1) continue;
      s.userData.fallT=Math.min(1, s.userData.fallT + dt*1.6);
      const t=s.userData.fallT;
      s.rotation.x = -Math.PI/2 * t;
      s.position.y = 2.73 - 2.205*t;
      if(t>=1){ s.position.y=0.525; }
    }
  }

  let remaining=300, lastTick=performance.now();
  function tickTimer(now){
    const dt=(now-lastTick)/1000; lastTick=now;
    remaining=Math.max(0, remaining-dt);
    const mm=String(Math.floor(remaining/60)).padStart(2,'0');
    const ss=String(Math.floor(remaining%60)).padStart(2,'0');
    $("pTime").textContent="⏱ "+mm+":"+ss;
  }

  // Vignette
  let vignette=0;
  const vign=document.createElement("div");
  vign.style.position="fixed"; vign.style.inset="0"; vign.style.pointerEvents="none";
  vign.style.zIndex="24";
  vign.style.background="radial-gradient(ellipse at center, rgba(0,0,0,0) 55%, rgba(0,0,0,0.78) 100%)";
  vign.style.opacity="0";
  document.body.appendChild(vign);

  function updateMonster(dt){
    if(!monster) return;
    if(monster.userData.locked) { return; }
    // If rabbit is already trapped in the locked cage, monster should not re-catch; it will patrol instead.
    let rabbitInCage=false, rabbitTrapped=false;
    try{ rabbitInCage = playerInsideCage(); rabbitTrapped = rabbitInCage && cage.userData.locked && !cage.userData.doorOpen; }catch(e){}

    // Stun handling
    if(monster.userData.stunT && monster.userData.stunT>0){
      monster.userData.stunT = Math.max(0, monster.userData.stunT - dt);
      if(monster.userData.stunRing){
        monster.userData.stunRing.visible = monster.userData.stunT>0;
        monster.userData.stunRing.rotation.z += dt*6.0;
      }
      // While stunned, do not move/chase.
    }
    monster.userData.t += dt;
    const t=monster.userData.t;
    monster.userData.armL.rotation.x = Math.sin(t*5)*0.22;
    monster.userData.armR.rotation.x = -Math.sin(t*5)*0.22;
    monster.position.y = Math.sin(t*3)*0.05;

    // distance to player is used for AI + proximity FX
    const dx=player.position.x-monster.position.x;
    const dz=player.position.z-monster.position.z;
    const d=Math.hypot(dx,dz);
    const nowMs = performance.now();

    // tension music: only when rabbit is free
    try{ updatePanicMusic((rabbitGhost || player.userData.trapped || rabbitTrapped || rabbitInCage)?999:d); }catch(e){}

    if(monsterAI){
      const stunned = (monster.userData.stunT && monster.userData.stunT>0);
      if(stunned){
        // While stunned: no movement, no catch.
        vignette*=0.92;
        vign.style.opacity=String(vignette*0.9);
        return;
      }

      const rabbitSpeed=6.8;

      // Aggro boost: if the rabbit is holding at least one key, monster becomes more persistent.
      const rabbitHasKey = (typeof keyCount==='number' && keyCount>=1);
      const chaseLeash = rabbitHasKey ? 45.0 : 25.0; // how far before it gives up and patrols
      const sprintStartRange = rabbitHasKey ? 14.0 : 9.0;
      const sprintChargeNeed = rabbitHasKey ? 0.60 : 0.999;


      // Patrol logic: when rabbit is trapped or far away, roam to random targets.
      const worldHalfX = (GW*CELL)*0.5 - 2.0;
      const worldHalfZ = (GH*CELL)*0.5 - 2.0;
      function pickPatrol(){
        monster.userData.patrolX = (Math.random()*2-1)*worldHalfX;
        monster.userData.patrolZ = (Math.random()*2-1)*worldHalfZ;
        monster.userData.patrolT = 3.0 + Math.random()*4.0;
      }
      function doPatrol(){
        if(monster.userData.patrolT<=0) pickPatrol();
        monster.userData.patrolT -= dt;
        const tx = monster.userData.patrolX;
        const tz = monster.userData.patrolZ;
        const pdx = tx - monster.position.x;
        const pdz = tz - monster.position.z;
        const pd = Math.hypot(pdx,pdz);
        const sp = rabbitSpeed*0.95;
        if(pd>0.05){
          const vx=(pdx/pd)*sp*dt, vz=(pdz/pd)*sp*dt;
          const oldX = monster.position.x, oldZ = monster.position.z;
          const nx=oldX+vx, nz=oldZ+vz;
          const pos = resolveMoveAt(oldX, oldZ, nx, nz, 0.60);
          monster.position.x = pos.x; monster.position.z = pos.z;
          if(pos.x===oldX && pos.z===oldZ){ monster.userData.patrolT = 0; }
          monster.rotation.y = Math.atan2(pdx,pdz);
        }else{
          monster.userData.patrolT = 0;
        }
      }

      if(rabbitInCage || d>chaseLeash){
        doPatrol();
        vignette*=0.92;
        vign.style.opacity=String(vignette*0.9);
        return;
      }

      // monster sprint (no toggle-cancel; once started runs full then must recharge)
      // Start only when fully charged; once active, cannot be canceled early.
      const canStartSprint = (!mSprint.active) && (mSprint.charge>=sprintChargeNeed);
      const wantStart = canStartSprint && (d<sprintStartRange || (rabbitHasKey && sprint.active));
      if(wantStart){
        mSprint.active = true;
        revealPingT = 2.0; // show rabbit ping on minimap briefly
      }
      if(mSprint.active){
        mSprint.charge = Math.max(0, mSprint.charge - mSprint.drain*dt);
        if(mSprint.charge<=0){ mSprint.active=false; }
      }else{
        mSprint.charge = Math.min(1, mSprint.charge + mSprint.regen*dt);
      }
      monsterSprintSfx(mSprint.active);
      const speedBuff = (nowMs < monsterSpeedBuffUntil) ? 1.5 : 1.0;
      const sp=7.9*(mSprint.active?mSprint.mult:1)*speedBuff;
      if(d>0.01){
        const vx=(dx/d)*sp*dt, vz=(dz/d)*sp*dt;
        const oldX = monster.position.x, oldZ = monster.position.z;
        const nx=oldX+vx, nz=oldZ+vz;
        // Use the same collision resolver as the player (prevents tunneling / wall phasing)
        let pos = resolveMoveAt(oldX, oldZ, nx, nz, 0.60);
        monster.position.x = pos.x; 
        monster.position.z = pos.z;

        // simple unstuck: if blocked, try a few sidesteps
        if(pos.x===oldX && pos.z===oldZ){
          for(let s=0;s<4;s++){
            const ox = (Math.random()*2-1)*0.55;
            const oz = (Math.random()*2-1)*0.55;
            const tx = oldX + ox;
            const tz = oldZ + oz;
            const p2 = resolveMoveAt(oldX, oldZ, tx, tz, 0.60);
            if(p2.x!==oldX || p2.z!==oldZ){ monster.position.x=p2.x; monster.position.z=p2.z; break; }
          }
        }
        monster.rotation.y=Math.atan2(dx,dz);
      }

      // Monster can re-lock one padlock every 120s if at least one is unlocked,
      // but only when it reaches the door.
      if(doorState && doorG){
        const ddx = doorG.position.x - monster.position.x;
        const ddz = doorG.position.z - monster.position.z;
        const dd = Math.hypot(ddx,ddz);
        sealLeft = Math.max(0, doorState.sealedUntil - performance.now());
        if(doorState.sealedUntil > performance.now()){
          sealSprite.visible = true;
          updateSealSprite((doorState.sealedUntil - performance.now())/1000);
        }else if(sealSprite.visible){
          sealSprite.visible = false;
          updateSealSprite(0);
          if(doorState.sealUsed){ addChat('[싱글] 탈출문 봉인이 해제되었다!'); }
          doorState.sealedUntil = 0;
          sealLeft = 0;
        }
        // Monster can seal the exit once for 10 seconds.
        if(!doorState.sealUsed && dd<2.2 && doorState.locksUnlocked>=1){
          doorState.sealUsed = true;
          doorState.sealedUntil = performance.now() + 10000;
          sealLeft = 10000;
          doorState.open = false;
          doorState.openT = 0;
          sealSprite.visible = true;
          updateSealSprite(10);
          beep(180,0.12,'sawtooth',0.30);
          addChat('[싱글] 괴물이 탈출문을 10초간 봉인했다!');
        }
      }
const v=Math.max(0, Math.min(1,(12-d)/10));
      vignette=vignette*0.90 + v*0.10;
      vign.style.opacity=String(vignette*0.9);
      if(!rabbitGhost && !player.userData.trapped && !rabbitInCage && d<7.0){
        monster.userData.warnBeepAt = monster.userData.warnBeepAt || 0;
        if(nowMs - monster.userData.warnBeepAt >= 420){
          monster.userData.warnBeepAt = nowMs;
          beep(180+Math.random()*30,0.03,"sine",0.045);
        }
      }
      // Bookshelf stun + clear
      // If monster touches a recently toppled shelf (within 1.5s), it gets stunned for 1s.
      // Also, monster can "clear" a fallen shelf by turning it into a red ball so it doesn't block paths.
      monster.userData.stunCd = Math.max(0, (monster.userData.stunCd||0) - dt);
      for(const s of shelves){
        if(!s || !s.userData || !s.userData.fallen || s.userData.cleared) continue;
        const hx = s.userData.halfX || (0.95*SHELF_SCALE);
        const hz = s.userData.halfZ || (0.375*SHELF_SCALE);
        const hit = hitAABB(monster.position.x, monster.position.z, s.position.x, s.position.z, hx, hz, 0.62);
        if(hit){
          // stun window
          if(s.userData.stunArmed && (nowMs - (s.userData.fellAt||0)) <= 1500){
            s.userData.stunArmed = false;
            monster.userData.stunT = 1.0;
            if(monster.userData.stunRing){ monster.userData.stunRing.visible = true; }
            beep(90,0.10,'square',0.22);
            addChat("[싱글] 괴물이 쓰러진 책장에 부딪혀 잠깐 기절했다!");
            return; // stunned immediately, skip catch this frame
          }
          // clear if not in stun window
          if(monster.userData.stunCd<=0 && (nowMs - (s.userData.fellAt||0)) > 400){
            // replace with a red ball at similar location
            s.userData.cleared = true;
            // remove shelf from scene + collision list
            try{
              const pi = props.indexOf(s);
              if(pi>=0) props.splice(pi,1);
            }catch(e){}
            scene.remove(s);
            const si = shelves.indexOf(s);
            if(si>=0) shelves.splice(si,1);
            spawnBall(s.position.x, s.position.z, 0.85);
            monster.userData.stunCd = 0.6;
            addChat("[싱글] 괴물이 넘어진 책장을 빨간 공으로 치웠다!");
            break;
          }
        }
      }

      if(!rabbitGhost && !rabbitInCage && d < (mSprint.active?1.8:1.25)){
        rabbitCaughtCount++;
        updateCaughtCloud();
        addChat("⚠️ 괴물에게 잡힘! ("+rabbitCaughtCount+"/2)");
        if(keyCount>=1){
          keyCount=0; $("pKey").textContent="🔑 "+keyCount; updateKeyIndicator();
          updateKeyIndicator();
          try{ placeKey(); }catch(e){}
          addChat('[싱글] 열쇠가 맵 어딘가로 다시 이동했다!');
        }
        if(rabbitCaughtCount>=2){
          makeRabbitGhost();
        }else{
          trapRabbitInCage(6);
        }
        if(huntActive){ huntLeft = 90; }
      }
    }else{
      // AI off: just fade proximity FX smoothly
      vignette*=0.92;
      vign.style.opacity=String(vignette*0.9);
    }
  }

  // Camera temp vectors (avoid per-frame allocations -> reduces micro-stutter/GC)
  const _camBack = new THREE.Vector3();
  const _camPos  = new THREE.Vector3();
  const _camUp   = new THREE.Vector3();

  function updateCamera(dt){
    // Apply role-based camera profile (rabbit: narrower, monster: wider)
    const prof = (playerRole==='monster') ? CAM_MONSTER : CAM_RABBIT;
    camDist = prof.dist;
    camHeight = prof.height;
    // Smooth FOV changes toward the target profile (rabbit/monster).
    // Using a small lerp avoids sudden zoom pop when role changes.
    const tf = prof.fov;
    _camFov = _camFov + (tf - _camFov) * 0.12;
    if(Math.abs(camera.fov - _camFov) > 0.05){
      camera.fov = _camFov;
      camera.updateProjectionMatrix();
    }
    _camBack.set(Math.sin(yaw), 0, Math.cos(yaw));
    _camUp.set(0, camHeight, 0);
    _camPos.copy(player.position).add(_camUp).addScaledVector(_camBack, -camDist);
    // dt-independent smoothing (kept stable)
    // Exponential smoothing (frame-rate independent) to reduce jitter.
    const a = 1 - Math.exp(-dt*12.0);
    camera.position.lerp(_camPos, a);
    camera.lookAt(player.position.x, player.position.y+1.0, player.position.z);
  }

  // minimap
  const mm=$("minimap");
  const mmCtx=mm.getContext("2d");
  function resizeMinimap(){
    const rect=mm.getBoundingClientRect();
    const dpr=Math.min(devicePixelRatio||1,2);
    mm.width=Math.floor(rect.width*dpr);
    mm.height=Math.floor(rect.height*dpr);
    mmCtx.setTransform(dpr,0,0,dpr,0,0);
  }
  resizeMinimap();

  function drawMinimap(){
    const w=mm.getBoundingClientRect().width, h=mm.getBoundingClientRect().height;
    mmCtx.clearRect(0,0,w,h);
    const pad=10;
    const sc=Math.min((w-2*pad)/(GW*CELL),(h-2*pad)/(GH*CELL));
    mmCtx.fillStyle="rgba(10,12,18,0.55)"; mmCtx.fillRect(0,0,w,h);

    const step=2;
    mmCtx.fillStyle="rgba(233,238,252,0.12)";
    for(let gy=0; gy<GH; gy+=step){
      for(let gx=0; gx<GW; gx+=step){
        if(grid[gy][gx]!==1) continue;
        const x=pad+(gx*CELL)*sc, y=pad+(gy*CELL)*sc;
        mmCtx.fillRect(x,y, step*CELL*sc, step*CELL*sc);
      }
    }
    function worldToMM(wx,wz){
      const gx=(wx/CELL + GW/2);
      const gy=(wz/CELL + GH/2);
      return {x: pad+(gx*CELL)*sc, y: pad+(gy*CELL)*sc};
    }
    const c=worldToMM(cage.position.x,cage.position.z);
    mmCtx.fillStyle="rgba(120,200,255,0.95)"; mmCtx.beginPath(); mmCtx.arc(c.x,c.y,4.2,0,Math.PI*2); mmCtx.fill();
    const d=worldToMM(doorG.position.x,doorG.position.z);
    mmCtx.fillStyle="rgba(80,255,120,0.95)"; mmCtx.beginPath(); mmCtx.arc(d.x,d.y,4.2,0,Math.PI*2); mmCtx.fill();
    const p=worldToMM(player.position.x,player.position.z);
    mmCtx.fillStyle="rgba(255,255,255,0.95)"; mmCtx.beginPath(); mmCtx.arc(p.x,p.y,3.8,0,Math.PI*2); mmCtx.fill();
    if(monster){ const mpos=worldToMM(monster.position.x,monster.position.z);
      mmCtx.fillStyle="rgba(255,80,80,0.95)"; mmCtx.beginPath(); mmCtx.arc(mpos.x,mpos.y,3.6,0,Math.PI*2); mmCtx.fill(); }
    if(revealPingT>0){ mmCtx.strokeStyle="rgba(255,220,90,0.95)"; mmCtx.lineWidth=2;
      mmCtx.beginPath(); mmCtx.arc(p.x,p.y,10 + (2-revealPingT)*6,0,Math.PI*2); mmCtx.stroke(); }
    mmCtx.strokeStyle="rgba(140,210,255,0.95)"; mmCtx.lineWidth=2;
    mmCtx.beginPath(); mmCtx.moveTo(p.x,p.y); mmCtx.lineTo(p.x+Math.sin(yaw)*10,p.y+Math.cos(yaw)*10); mmCtx.stroke();
    mmCtx.strokeStyle="rgba(255,255,255,0.12)"; mmCtx.lineWidth=1; mmCtx.strokeRect(0.5,0.5,w-1,h-1);
  }

  function onResize(){
    camera.aspect=innerWidth/innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(innerWidth,innerHeight);
    updateChatH();
    resizeMinimap();
  }
  addEventListener("resize", onResize);

  hideLoading(); setSub("");

  
  function isInPool(x,z){
    for(const p of poolZones){
      const rx = Math.max(0.01, Number(p.rx || p.hx || 0));
      const rz = Math.max(0.01, Number(p.rz || p.hz || 0));
      const dx = (x - p.cx) / rx;
      const dz = (z - p.cz) / rz;
      if((dx*dx + dz*dz) <= 1) return true;
    }
    return false;
  }

let last=performance.now();
  function animate(now){
    const dt=Math.min(0.033,(now-last)/1000); last=now;
    try{
// Global countdown for monster release (visible to both)
if(monsterReleaseLeft>0){
  monsterReleaseLeft = Math.max(0, monsterReleaseLeft - dt);
  countdownEl.style.display = "block";
  countdownEl.textContent = "괴물 해방까지 " + Math.ceil(monsterReleaseLeft);
  // Keep monster locked in its room until release
  if(monster) monster.userData.locked = true;
  /* keep monsterAI flag as-is; only lock movement */
}else{
  if(countdownEl.style.display!=="none") countdownEl.style.display="none";
  if(monsterGate){
    // Remove gate collider/mesh once
    const i = props.indexOf(monsterGate);
    if(i>=0) props.splice(i,1);
    monsterGate.parent && monsterGate.parent.remove(monsterGate);
    monsterGate = null;
  }
  if(monster) monster.userData.locked = false;
  if(!huntActive){ huntActive=true; huntLeft=90; }
}


    // Animate exit door (double swing) + lock unlock animation
    {
      const locks = (doorG.userData && doorG.userData.locks) ? doorG.userData.locks : [];
      for(const lk of locks){
        if(lk && lk.userData && lk.userData.t>0){
          // unlock animation: rotate and lift, then fade out
          lk.userData.t = Math.max(0, lk.userData.t - dt*1.25);
          const a = (1 - lk.userData.t);
          lk.rotation.y = a * Math.PI*1.25;
          lk.position.y = 0.20 + a*0.55;
          lk.scale.setScalar(1 - a*0.55);
          if(lk.userData.t<=0.001) lk.visible = false;
        }
      }
      if(doorState.open){
        doorState.openT = Math.min(1, doorState.openT + dt*1.1);
        const t = doorState.openT;
        // swing outward
        const ang = t * (Math.PI*0.46);
        if(doorG.userData.leftPivot) doorG.userData.leftPivot.rotation.y = -ang;
        if(doorG.userData.rightPivot) doorG.userData.rightPivot.rotation.y = ang;
      }else{
        // keep closed
        if(doorG.userData.leftPivot) doorG.userData.leftPivot.rotation.y = 0;
        if(doorG.userData.rightPivot) doorG.userData.rightPivot.rotation.y = 0;
      }
    }
    tickTimer(now);

    // Sprint charge update + UI
    if(sprint.active){
      // carrot buff: rabbit can sprint without draining for 5s
      const _noDrain = (now < rabbitNoDrainUntil) || (now < rabbitFreeSprintUntil);
      sprint.charge = _noDrain ? Math.max(sprint.charge, 1) : Math.max(0, sprint.charge - sprint.drain*dt);
      if(sprint.charge<=0.0001) sprint.active=false;
    }else{
      sprint.charge = Math.min(1, sprint.charge + sprint.regen*dt);
    }
    // meter: show used portion by clipping the overlay from top-down
        const used = Math.min(1, Math.max(0, 1 - sprint.charge));
    sprintMeter.style.transform = `scaleY(${used.toFixed(3)})`;
    if(sprintMeterEdge){ sprintMeterEdge.style.top = `${(used*100).toFixed(1)}%`; }


    for(const k of keys){
      // Key visibility rule: if in seeker-view and no rabbit is holding a key, hide ground keys
      k.visible = !(seekerView && keyCount<=0);
      k.rotation.y += dt*1.8;
      k.rotation.x = Math.sin(now/420 + k.userData.phase)*0.10;
      k.position.y = k.userData.baseY + Math.sin(now/450 + k.userData.phase)*0.22;
    }
    tubeAnimAcc += dt;
    if (tubeAnimAcc >= 1/18){
      tubeAnimAcc = 0;
      for(const t of tubes){
        t.flicker += dt * 1.2;
        const f = 0.94 + 0.08*Math.sin(t.flicker*2.0) + (Math.random()<0.002 ? -0.18 : 0);
        t.mesh.material.emissiveIntensity = 1.22*Math.max(0.55, f);
        if(t.light) t.light.intensity = 0.42*Math.max(0.35, f);
      }
    }

    const turn=(keysDown.a?1:0)-(keysDown.d?1:0)+(-joyX);
    yaw += turn*2.35*dt;

    const fb=(keysDown.w?1:0)-(keysDown.s?1:0)+(-joyY);
    // sprint / water slow
    const inWater = isInPool(player.position.x, player.position.z);
    const wantSprint = (!promptVisible()) && (sprint.hold || shiftHeld);
    const rabbitFreeSprint = (performance.now() < rabbitFreeSprintUntil);
    sprint.active = wantSprint && (rabbitFreeSprint || sprint.charge>0.001);
    const speedMul = (inWater?0.5:1) * (sprint.active ? sprint.mult : 1);
    const rabbitSpeed = 7.4 * speedMul;
    // If the rabbit is trapped, hard-anchor them to the cage center so they cannot drift outside the bars.
    let trappedInCage = false;
    try{ trappedInCage = !!player.userData.trapped && cage.userData.locked && !cage.userData.doorOpen; }catch(e){}
    if(trappedInCage){
      sprint.active = false;
      const slot = getCageSlot(6);
      player.position.x = slot.x;
      player.position.z = slot.z;
    }

    // Movement sub-steps to reduce tunneling/bounce at high speed (especially during sprint)
    const mvScale = (typeof trappedInCage!=="undefined" && trappedInCage) ? 0 : 1;
    const mvx=Math.sin(yaw)*fb*rabbitSpeed*mvScale;
    const mvz=Math.cos(yaw)*fb*rabbitSpeed*mvScale;
    const dist = Math.hypot(mvx, mvz) * dt;
    const steps = Math.max(1, Math.ceil(dist / 0.22)); // <= 22cm per step
    const stepDt = dt / steps;

    const prevPx = player.position.x;
    const prevPz = player.position.z;
    for(let s=0; s<steps; s++){
      const vx = mvx * stepDt;
      const vz = mvz * stepDt;
      const nx = player.position.x + vx;
      const nz = player.position.z + vz;
      const pos = resolveMove(nx, nz);
      player.position.x = pos.x; 
      player.position.z = pos.z;
    }
    player.userData.vx = (player.position.x - prevPx) / Math.max(dt, 1e-4);
    player.userData.vz = (player.position.z - prevPz) / Math.max(dt, 1e-4);
    if (Math.abs(fb) <= 0.01 || mvScale === 0){ player.userData.vx = 0; player.userData.vz = 0; }
    player.rotation.y=yaw;
    animateCaughtCloud(dt);
    // footsteps
    if(Math.abs(fb)>0.05){
      stepAcc += dt * (sprint.active?1.6:1.0) * (isInPool(player.position.x,player.position.z)?0.55:1.0);
      if(stepAcc>0.38){
        stepAcc=0;
        const f = isInPool(player.position.x,player.position.z)? 220 : 320;
        beep(f+Math.random()*30, 0.035, "square", 0.12);
      }
    }else{
      stepAcc = Math.max(0, stepAcc - dt*2.0);
    }
    handlePush(dt);
    updatePushables(dt);
    updateShelves(dt);

    // Carrot pickups
    try{ tryPickupCarrots(); }catch(e){}
// Cage auto-relock countdown
    try{
      if(cage.userData.doorOpen && cage.userData.autoCloseT>0){
        cage.userData.autoCloseT -= dt;
        setCageCountdown(cage.userData.autoCloseT);
        cageCdSprite.visible = true;
        if(cage.userData.autoCloseT <= 0){
          cage.userData.doorOpen = 0;
          cage.userData.locked = true;
          const lock = cage.getObjectByName("cageLock");
          if(lock) lock.visible = true;
          cageCdSprite.visible = false;
          addChat("철창이 다시 잠겼다.");
        }
      }
    }catch(e){}
    // Cage door animation
    try{
      const hinge=cage.getObjectByName("cageHinge");
      if(hinge){
        const target = cage.userData.doorOpen? -Math.PI*0.75 : 0;
        hinge.rotation.y += (target - hinge.rotation.y) * Math.min(1, dt*8);
      }
    }catch(e){}

    updatePrompt();
    updateCamera(dt);
    updateMonster(dt);

    const mmGap = (bridge && bridge.start && (bridge.start.playerCount||0) >= 2) ? 200 : 150; // [FIX] 미니맵 더 자주 업데이트
    if (!window.__brLastMiniMapDraw || (now - window.__brLastMiniMapDraw) > mmGap){ window.__brLastMiniMapDraw = now; drawMinimap(); }

    renderer.render(scene,camera);
    }catch(e){ console.error(e); }

    try{ window.__BR3D_RAF_ID__ = requestAnimationFrame(animate); }catch(_){ requestAnimationFrame(animate); }
  }

  // Backrooms multiplayer bridge lives inside run3D so it can use the real runtime state.
  const q=(id)=>document.getElementById(id);
  const qs=new URLSearchParams(location.search);
  const roomId=window.__BR_ROOM_ID__ || qs.get('roomId') || '';
  let bridge={ sid:String(window.__BR_BOOT_ID__||'')||null, nick:String(window.__BR_BOOT_NICK__||'Player'), isHost:!!window.__BR_BOOT_HOST__, selfSeat:Number(window.__BR_BOOT_SEAT__ ?? -1), roomId, start:(window.__BR_START__||null), active:false, remotes:new Map(), lastStateAt:0, lastWorldAt:0, lastCatchAt:0, stateSeq:0, hostSid:null, forceSpawnUntil:0, ignoreCaughtUntil:0, startId:null, spawn:null, spawnApplied:false, prevAnimateNow:0 };
  let pendingStartPayload = null;
  let helperMonster = null, helperRemote = null, helperState = null;
  const bridgeStateCache = { x:null, y:null, z:null, yaw:null, hasKey:null, caught:null, ghost:null, trapped:null, sentAt:0 };
  function post(msg){ try{ parent.postMessage(Object.assign({ gameId:'backrooms3d' }, msg||{}),'*'); }catch(_){ } }
  const brExitBtn = document.getElementById('brExitBtn');
  if (brExitBtn) brExitBtn.addEventListener('click', ()=>{ post({ type:'br_exit_to_lobby' }); });
  function relay(kind, data){ post({ type:'br_msg', msg:Object.assign({ kind }, data||{}) }); }
  function sanitizeStoredStart(sp){
    try{
      if (!sp || typeof sp !== 'object') return null;
      const clean = Object.assign({}, sp);
      delete clean.mySid;
      delete clean.mySeat;
      delete clean.myHost;
      return clean;
    }catch(_){ return null; }
  }
  function storageStart(){ return null; }
  function clearStoredStart(){}
  function startHasCurrentPlayer(sp){
    try{
      if (!sp || typeof sp !== 'object') return false;
      const sid = String(sp.mySid || bridge?.sid || '');
      const seat = Number.isFinite(Number(sp.mySeat)) ? Number(sp.mySeat) : Number(bridge?.selfSeat ?? -1);
      const roles = (sp.roles && typeof sp.roles === 'object') ? sp.roles : null;
      if (sid && roles && Object.prototype.hasOwnProperty.call(roles, sid)) return true;
      const roster = Array.isArray(sp.roster) ? sp.roster : [];
      if (!roster.length || !sid) return false;
      return roster.some(r => String(r?.sid||'') === sid);
    }catch(_){ return false; }
  }
  function storeStart(sp){ return; }
  function findRosterSid(){
    try{
      const ord = parent && parent.room && parent.room.state && parent.room.state.order;
      return null;
    }catch(_){ return null; }
  }
  function findHostSid(start){
    const roster = Array.isArray(start?.roster) ? start.roster.slice() : [];
    roster.sort((a,b)=> (a.seat??99)-(b.seat??99) || String(a.sid).localeCompare(String(b.sid)));
    const h = roster.find(r=>r && r.isHost) || roster[0];
    return h ? String(h.sid) : null;
  }

  function resolveRoleForSid(start, sid, seat, fallbackRole){
    const id = String(sid || '');
    if (!start || typeof start !== 'object') return String(fallbackRole || 'rabbit');
    if (id && String(start?.mySid || '') === id && start?.myRole) return String(start.myRole);
    if (start.roles && id && start.roles[id] && start.roles[id].role) return String(start.roles[id].role);
    const roster = Array.isArray(start.roster) ? start.roster : [];
    const match = id ? roster.find(r => String(r?.sid||'') === id) : null;
    if (match && start.roles && start.roles[String(match.sid)]?.role) return String(start.roles[String(match.sid)].role);
    return String(fallbackRole || 'rabbit');
  }

  function authoritativeMonsterSid(start){
    const roster = Array.isArray(start?.roster) ? start.roster.slice() : [];
    if (Number(start?.playerCount||roster.length||0) < 2 || !roster.length) return null;
    if (start && start.monsterSid != null && String(start.monsterSid||'')) return String(start.monsterSid);
    const seed = Number(start?.seed||0) >>> 0;
    roster.sort((a,b)=> (Number(a?.seat??99)-Number(b?.seat??99)) || String(a?.sid||'').localeCompare(String(b?.sid||'')));
    return String(roster[seed % roster.length]?.sid || roster[0]?.sid || '');
  }
  function authoritativeMonsterSeat(start){
    const roster = Array.isArray(start?.roster) ? start.roster.slice() : [];
    if (Number(start?.playerCount||roster.length||0) < 2 || !roster.length) return -1;
    const monsterSid = authoritativeMonsterSid(start);
    const match = roster.find(r => String(r?.sid||'') === String(monsterSid||''));
    if (match && Number.isFinite(Number(match?.seat))) return Number(match.seat);
    const seed = Number(start?.seed||0) >>> 0;
    roster.sort((a,b)=> (Number(a?.seat??99)-Number(b?.seat??99)) || String(a?.sid||'').localeCompare(String(b?.sid||'')));
    return Number(roster[seed % roster.length]?.seat ?? -1);
  }

  function rabbitSpawnSlots(){
    const baseZ = cage.userData.D/2 + 2.2;
    return [
      {x:-4.8,z:baseZ+0.45},{x:-3.2,z:baseZ+0.18},{x:-1.6,z:baseZ-0.05},
      {x:0.0,z:baseZ-0.16},{x:1.6,z:baseZ-0.05},{x:3.2,z:baseZ+0.18},{x:4.8,z:baseZ+0.45}
    ];
  }
  function rabbitSeatIndex(start, sid){
    const roster = Array.isArray(start?.roster) ? start.roster.slice() : [];
    const monsterSid = authoritativeMonsterSid(start) || '';
    const rabbits = roster.filter(r=>String(r?.sid||'') !== monsterSid);
    rabbits.sort((a,b)=> (Number(a?.seat??99)-Number(b?.seat??99)) || String(a?.sid||'').localeCompare(String(b?.sid||'')));
    const idx = rabbits.findIndex(r=>String(r?.sid||'')===String(sid||''));
    return idx >= 0 ? idx : 0;
  }
  function rabbitSpawnFor(start, sid){
    const slots = rabbitSpawnSlots();
    const idx = Math.max(0, Math.min(slots.length-1, rabbitSeatIndex(start, sid)));
    return slots[idx];
  }
  function defaultSpawnYawForRole(role){
    // y=0 faces toward +Z. That points rabbits away from the cage and points the monster toward the room doorway.
    return 0;
  }

  function isSpawnPointFree(x, z, rad=0.60){
    try{ return !collidesWalls(x, z, rad) && !collidesProps(x, z, rad); }catch(_){ return true; }
  }
  function findNearestFreeSpawn(spawn, fallback){
    const base = {
      x: Number(spawn?.x)||0,
      y: Number(spawn?.y)||0.05,
      z: Number(spawn?.z)||0,
      yaw: Number.isFinite(Number(spawn?.yaw)) ? Number(spawn.yaw) : Math.PI
    };
    if (isSpawnPointFree(base.x, base.z)) return base;
    const fall = {
      x: Number(fallback?.x)||0,
      y: Number(fallback?.y)||0.05,
      z: Number(fallback?.z)||0,
      yaw: Number.isFinite(Number(fallback?.yaw)) ? Number(fallback.yaw) : base.yaw
    };
    if (isSpawnPointFree(fall.x, fall.z)) return fall;
    const step = 0.45;
    for(let ring=1; ring<=12; ring++){
      const r = ring * step;
      const samples = Math.max(8, ring * 10);
      for(let i=0; i<samples; i++){
        const a = (Math.PI*2 * i) / samples;
        const cand = { x: base.x + Math.cos(a) * r, y: base.y, z: base.z + Math.sin(a) * r, yaw: base.yaw };
        if (isSpawnPointFree(cand.x, cand.z)) return cand;
      }
    }
    return fall;
  }
  function sameBridgeStart(a, b){
    try{
      if (!a || !b) return false;
      const aid = String(a.startId || a.startedAt || '');
      const bid = String(b.startId || b.startedAt || '');
      if (aid && bid) return aid === bid;
      return JSON.stringify(a.roles || {}) === JSON.stringify(b.roles || {}) && JSON.stringify(a.roster || []) === JSON.stringify(b.roster || []);
    }catch(_){ return false; }
  }
  function getBridgeStart(){
    return (bridge && bridge.start && String(bridge.start.mode || '') === 'backrooms3d') ? bridge.start : null;
  }
  function setBridgeIdentity(partial){
    if (!partial || typeof partial !== 'object') return;
    if (partial.sid !== undefined && partial.sid !== null && String(partial.sid) !== '') bridge.sid = String(partial.sid);
    if (partial.nick !== undefined && partial.nick !== null && String(partial.nick) !== '') bridge.nick = String(partial.nick);
    if (partial.roomId !== undefined && partial.roomId !== null && String(partial.roomId) !== '') bridge.roomId = String(partial.roomId);
    if (Number.isFinite(Number(partial.selfSeat))) bridge.selfSeat = Number(partial.selfSeat);
    if (typeof partial.isHost === 'boolean') bridge.isHost = !!partial.isHost;
  }
  function applyBridgeStartPayload(startPayload, identity){
    if (!startPayload || String(startPayload.mode || '') !== 'backrooms3d') return false;
    const prevSid = String(bridge.sid || '');
    const prevSeat = Number.isFinite(Number(bridge.selfSeat)) ? Number(bridge.selfSeat) : -1;
    const prevHost = !!bridge.isHost;
    setBridgeIdentity(identity || {});
    const merged = Object.assign({}, startPayload, {
      mySid: String(startPayload.mySid || bridge.sid || ''),
      mySeat: Number.isFinite(Number(startPayload.mySeat)) ? Number(startPayload.mySeat) : Number(bridge.selfSeat ?? -1),
      myHost: (typeof startPayload.myHost === 'boolean') ? !!startPayload.myHost : !!bridge.isHost,
    });
    if (merged.mySid && !bridge.sid) bridge.sid = String(merged.mySid);
    if (Number.isFinite(Number(merged.mySeat)) && Number(prevSeat) < 0) bridge.selfSeat = Number(merged.mySeat);
    if (typeof merged.myHost === 'boolean' && !prevHost) bridge.isHost = !!merged.myHost;
    if (!startHasCurrentPlayer(merged)) return false;
    const sameStart = sameBridgeStart(bridge.start, merged);
    const identityChanged = (String(bridge.sid||'') !== prevSid) || (Number(bridge.selfSeat ?? -1) !== prevSeat) || (!!bridge.isHost !== prevHost);
    bridge.start = merged;
    storeStart(bridge.start);
    bridge.active = Number(bridge.start.playerCount || 0) >= 2;
    // sameStart여도 playerRole이 아직 올바르게 설정되지 않았으면 강제 재적용
    const expectedRole = (() => {
      const mSid = authoritativeMonsterSid(merged);
      return (mSid && bridge.sid && String(mSid) === String(bridge.sid)) ? 'monster' : 'rabbit';
    })();
    const roleNotApplied = (playerRole !== expectedRole);
    if (!sameStart || identityChanged || roleNotApplied) applyRoleAndSpawn();
    return true;
  }

  function applyRoleAndSpawn(){
    if (!bridge.start) return;
    const start = getBridgeStart();
    if (!start) return;
    bridge.hostSid = findHostSid(start);
    if (typeof start.myHost === 'boolean') bridge.isHost = !!start.myHost;
    else bridge.isHost = !!((bridge.sid && bridge.hostSid && bridge.sid === bridge.hostSid) || (!bridge.hostSid && window.__BR_BOOT_HOST__));
    const monsterSid = authoritativeMonsterSid(start);
    const monsterSeat = Number.isFinite(Number(start?.monsterSeat)) ? Number(start.monsterSeat) : authoritativeMonsterSeat(start);
    const selfSeat = Number.isFinite(Number(start.mySeat)) ? Number(start.mySeat) : Number(bridge.selfSeat ?? -1);
    bridge.selfSeat = selfSeat;
    bridge.active = Number(start.playerCount || 0) >= 2;
    const roleEntry = bridge.sid && start && start.roles ? start.roles[String(bridge.sid)] : null;
    let directMyRole = String(start?.myRole || (roleEntry && roleEntry.role) || '');
    // myRole/roleEntry가 없으면 authoritativeMonsterSid로 직접 판별
    if (directMyRole !== 'monster' && directMyRole !== 'rabbit') {
      const mSid = authoritativeMonsterSid(start);
      directMyRole = (mSid && bridge.sid && String(mSid) === String(bridge.sid)) ? 'monster' : 'rabbit';
    }
    if (directMyRole !== 'monster' && directMyRole !== 'rabbit') return;
    playerRole = directMyRole;
    syncUiState();
    renderHelp();
    monsterAI = false;
    // [FIX] 역할 확정 후 로그
    addChat('[시스템] 역할 배정: ' + (playerRole === 'monster' ? '👾 괴물' : '🐰 토끼'));
    ensureMonster();
    try{ for (const [,r] of bridge.remotes.entries()){ try{ if(r && r.obj) scene.remove(r.obj); }catch(_){} } bridge.remotes.clear(); }catch(_){ }
    seedRemotesFromStart(start);
    const nowMs = performance.now();
    bridge.startId = String(start.startId || start.startedAt || '');
    const spawnLockMs = Math.max(700, Number(start.spawnLockMs || 900));
    const ignoreCaughtMs = Math.max(2500, Number(start.ignoreCaughtMs || 10000));
    const startedAtMs = Number(start.startedAt || Date.now());
    bridge.forceSpawnUntil = nowMs + Math.max(250, spawnLockMs - Math.max(0, Date.now() - startedAtMs));
    bridge.ignoreCaughtUntil = nowMs + Math.max(400, ignoreCaughtMs - Math.max(0, Date.now() - startedAtMs));
    monsterReleaseLeft = Math.max(0, (spawnLockMs - Math.max(0, Date.now() - startedAtMs)) / 1000);
    bridge.spawnApplied = false;
    let spawn = null;
    if (start && start.mySpawn) spawn = start.mySpawn;
    else if (roleEntry && roleEntry.spawn) spawn = roleEntry.spawn;
    else if (playerRole === 'monster') spawn = { x:monsterRoom.cx, y:0.05, z:monsterRoom.cz - monsterRoom.d*0.15, yaw:0 };
    else spawn = Object.assign({ y:0.05, yaw:defaultSpawnYawForRole('rabbit') }, rabbitSpawnFor(start, bridge.sid));
    const fallbackSpawn = (playerRole === 'monster')
      ? { x:monsterRoom.cx, y:0.05, z:monsterRoom.cz - monsterRoom.d*0.15, yaw:0 }
      : { x:0, y:0.05, z:cage.userData.D/2 + 2.8, yaw:defaultSpawnYawForRole('rabbit') };
    bridge.spawn = findNearestFreeSpawn(spawn, fallbackSpawn);
    try{ monster.userData.locked = true; }catch(_){ }
    try{ rabbitCaughtCount = 0; resetRabbitStateVisual(); }catch(_){ }
    try{ cage.userData.locked = true; cage.userData.doorOpen = 0; cage.userData.autoCloseT = 0; }catch(_){ }
    if (playerRole === 'monster'){
      player.visible = false;
      monster.visible = true;
      monster.userData.locked = true; // [FIX] 스폰 직후 10초 잠금은 monsterReleaseLeft로 관리
      player.position.set(bridge.spawn.x, bridge.spawn.y, bridge.spawn.z);
      monster.position.set(bridge.spawn.x, bridge.spawn.y, bridge.spawn.z);
      yaw = bridge.spawn.yaw;
      player.rotation.y = yaw;
      monster.rotation.y = yaw;
      bridge.spawnApplied = true;
      try{ updatePanicMusic(999); }catch(_){ }
    } else {
      player.visible = !rabbitGhost;
      monster.visible = false;
      player.position.set(bridge.spawn.x, bridge.spawn.y, bridge.spawn.z);
      yaw = bridge.spawn.yaw;
      player.rotation.y = yaw;
      bridge.spawnApplied = true;
    }
  }
  function makeRemoteAvatar(role){
    const g = new THREE.Group();
    if (role === 'monster'){
      const mat = new THREE.MeshStandardMaterial({color:0x11131a, roughness:0.92});
      const glow = new THREE.MeshStandardMaterial({color:0xff3b3b, emissive:0xff2b2b, emissiveIntensity:1.0});
      const body = new THREE.Mesh(new THREE.CapsuleGeometry(0.56,1.20,3,6), mat);
      body.position.y = 1.45; g.add(body);
      const head = new THREE.Mesh(new THREE.SphereGeometry(0.42, 6, 6), mat);
      head.position.y = 2.45; g.add(head);
      const eyeL = new THREE.Mesh(new THREE.SphereGeometry(0.06, 6, 6), glow);
      const eyeR = eyeL.clone();
      eyeL.position.set(-0.13,2.48,0.32); eyeR.position.set(0.13,2.48,0.32);
      g.add(eyeL, eyeR);
    } else {
      const mat = new THREE.MeshStandardMaterial({color:0xe9eefc, roughness:0.96});
      const pink = new THREE.MeshStandardMaterial({color:0xffc8d6, roughness:0.92});
      const eyeM = new THREE.MeshStandardMaterial({color:0x11131a, roughness:0.5});
      const body = new THREE.Mesh(new THREE.SphereGeometry(0.52, 10, 10), mat);
      body.scale.set(1.0,0.92,1.08); g.add(body);
      const head = new THREE.Mesh(new THREE.SphereGeometry(0.34, 10, 10), mat);
      head.position.set(0,0.30,0.32); g.add(head);
      const earGeo = new THREE.CapsuleGeometry(0.09,0.34,3,6);
      const earL = new THREE.Mesh(earGeo, mat); earL.position.set(-0.14,0.68,0.38); earL.rotation.x = 0.12; g.add(earL);
      const earR = earL.clone(); earR.position.x = 0.14; g.add(earR);
      const nose = new THREE.Mesh(new THREE.SphereGeometry(0.035, 6, 6), pink);
      nose.position.set(0,0.25,0.64); g.add(nose);
      const eyeL = new THREE.Mesh(new THREE.SphereGeometry(0.04, 6,6), eyeM);
      const eyeR = eyeL.clone();
      eyeL.position.set(-0.10,0.34,0.58); eyeR.position.set(0.10,0.34,0.58);
      g.add(eyeL,eyeR);
      g.scale.setScalar(0.72);
      const ki = makeKey(); ki.name='remoteKey'; ki.scale.setScalar(0.75); ki.position.set(0,2.15,0); ki.visible=false; g.add(ki);
      const cc = makeCaughtCloud(); cc.name='remoteCaught'; cc.visible=false; g.add(cc);
    }
    g.visible = false;
    scene.add(g);
    return g;
  }

  function setMonsterTransparency(root, alpha=1){
    if(!root) return;
    root.traverse?.((obj)=>{
      const mat = obj && obj.material;
      if(!mat) return;
      const mats = Array.isArray(mat) ? mat : [mat];
      mats.forEach((m)=>{
        if(!m) return;
        m.transparent = alpha < 0.999;
        m.opacity = alpha;
        m.depthWrite = alpha >= 0.999;
      });
    });
  }
  function ensureHelperMonster(){ return null; }
  function ensureHelperRemote(){ return null; }
  function snapshotHelper(){ return null; }
  function sendHelperState(force){ return; }
  function applyHelperState(m){ return; }
  function updateHelperMonster(dt){ return; }

  function ensureRemote(sid, role, initialState){
    sid=String(sid||''); if(!sid || sid===bridge.sid) return null;
    let r = bridge.remotes.get(sid);
    if(!r || r.role!==role){
      const prev = r && r.obj ? r.obj : null;
      const px = (initialState && Number.isFinite(Number(initialState.x))) ? Number(initialState.x) : (prev ? prev.position.x : 0);
      const py = (initialState && Number.isFinite(Number(initialState.y))) ? Number(initialState.y) : (prev ? prev.position.y : 0);
      const pz = (initialState && Number.isFinite(Number(initialState.z))) ? Number(initialState.z) : (prev ? prev.position.z : 0);
      const pry = (initialState && Number.isFinite(Number(initialState.yaw))) ? Number(initialState.yaw) : (prev ? prev.rotation.y : 0);
      if(prev){ try{ scene.remove(prev); }catch(_){ } }
      const obj = makeRemoteAvatar(role);
      obj.position.set(px, py, pz);
      obj.rotation.y = pry;
      obj.visible = !!initialState;
      r = { sid, role, obj, state:(initialState ? Object.assign({}, initialState, { role }) : null), lastSeq:-1, targetX:px, targetY:py, targetZ:pz, targetYaw:pry, lastAt:performance.now() };
      bridge.remotes.set(sid, r);
    } else if (initialState){
      r.obj.position.set(Number(initialState.x)||0, Number(initialState.y)||0, Number(initialState.z)||0);
      r.obj.rotation.y = Number(initialState.yaw)||0;
      r.obj.visible = true;
      r.state = Object.assign({}, initialState, { role });
      r.targetX = Number(initialState.x)||0;
      r.targetY = Number(initialState.y)||0;
      r.targetZ = Number(initialState.z)||0;
      r.targetYaw = Number(initialState.yaw)||0;
      r.lastAt = performance.now();
    }
    return r;
  }

  function seedRemotesFromStart(start){
    try{
      if(!start || !Array.isArray(start.roster)) return;
      const roles = (start.roles && typeof start.roles === 'object') ? start.roles : {};
      for(const entry of start.roster){
        const sid = String(entry?.sid || '');
        if(!sid || sid === String(bridge.sid||'')) continue;
        const roleInfo = roles[sid] || {};
        const role = String(roleInfo.role || resolveRoleForSid(start, sid, Number(entry?.seat ?? -1), 'rabbit'));
        if (role !== 'monster' && role !== 'rabbit') continue;
        let sp = roleInfo.spawn || null;
        if(!sp){
          if(role === 'monster') sp = { x:monsterRoom.cx, y:0.05, z:monsterRoom.cz - monsterRoom.d*0.15, yaw:0 };
          else sp = Object.assign({ y:0.05, yaw:defaultSpawnYawForRole('rabbit') }, rabbitSpawnFor(start, sid));
        }
        ensureRemote(sid, role, Object.assign({ x:0, y:0.05, z:0, yaw:0, hasKey:false, caught:0, ghost:false, trapped:false }, sp, { sid, from:sid, seat:Number(entry?.seat ?? -1), role }));
      }
    }catch(_){ }
  }

  // carts and balls stay local-only to reduce sync cost; shared world keeps only meaningful blocking/interactable props
  function snapshotDynamicProps(){
    const out = [];
    for(const o of (props||[])){
      const kind = String(o?.userData?.kind||'');
      if(!['crate','pillar','block'].includes(kind)) continue;
      const item = { kind, netKey:String(o?.userData?.netKey || `${kind}:${out.length}`), x:+o.position.x.toFixed(3), y:+o.position.y.toFixed(3), z:+o.position.z.toFixed(3), ry:+(o.rotation?.y||0).toFixed(3) };
      if(kind==='crate' || kind==='pillar' || kind==='block'){
        item.hx=+((o.userData?.halfX)||0.6).toFixed(3);
        item.hz=+((o.userData?.halfZ)||0.6).toFixed(3);
        item.h=+(o.position.y*2).toFixed(3);
        item.color=(o.material?.color?.getHex?.()||0xb7a86a);
      }
      out.push(item);
    }
    return out;
  }
  function clearDynamicProps(){
    for(let i=props.length-1;i>=0;i--){
      const o = props[i];
      const kind = String(o?.userData?.kind||'');
      if(!['crate','pillar','block'].includes(kind)) continue;
      props.splice(i,1);
      try{ scene.remove(o); }catch(_){ }
    }
    if(Array.isArray(shelves)) shelves.length = 0;
  }
  function restoreDynamicProps(items){
    const syncedKinds = new Set(['crate','pillar','block']);
    const existing = new Map();
    for(const o of (props||[])){
      const kind = String(o?.userData?.kind||'');
      if(!syncedKinds.has(kind)) continue;
      const key = String(o?.userData?.netKey || '');
      if(key) existing.set(key, o);
    }
    const keep = new Set();
    let idx = 0;
    for(const it of (items||[])){
      const kind = String(it?.kind||'');
      if(!syncedKinds.has(kind)) { idx++; continue; }
      const x = Number(it?.x)||0, z = Number(it?.z)||0;
      const ry = Number(it?.ry)||0;
      const hh = Number(it.h)||1.2;
      const hx = (Number(it.hx)||0.6);
      const hz = (Number(it.hz)||0.6);
      const netKey = String(it?.netKey || `${kind}:${idx++}`);
      let o = existing.get(netKey) || null;
      if(!o){
        if(kind==='crate'){ spawnCrate(x, z, hx*2, hz*2, hh); o = props[props.length-1]; }
        else if(kind==='pillar'){ spawnPillar(x, z, hx, hh||4.0); o = props[props.length-1]; }
        else if(kind==='block'){
          const m = new THREE.MeshStandardMaterial({color:Number(it.color)||0xb7a86a, roughness:0.8});
          const box = new THREE.Mesh(new THREE.BoxGeometry(hx*2,hh,hz*2), m);
          box.position.set(x, hh/2, z); box.rotation.y = ry; box.castShadow=true; box.receiveShadow=true;
          scene.add(box); addAABB(box, hx, hz, 'block'); o = props[props.length-1];
        }
        if(o) o.userData.netKey = netKey;
      }
      if(!o) continue;
      keep.add(o);
      o.userData.netKey = netKey;
      o.position.set(x, kind==='pillar' ? hh/2 : hh/2, z);
      o.rotation.y = ry;
      o.userData.halfX = hx;
      o.userData.halfZ = hz;
      if(o.material?.color && Number.isFinite(Number(it.color))) o.material.color.setHex(Number(it.color));
      if(o.geometry && kind==='block'){
        const sx=hx*2, sz=hz*2;
        if(Math.abs((o.geometry.parameters?.width||0)-sx) > 0.01 || Math.abs((o.geometry.parameters?.height||0)-hh) > 0.01 || Math.abs((o.geometry.parameters?.depth||0)-sz) > 0.01){
          try{ o.geometry.dispose(); }catch(_){ }
          o.geometry = new THREE.BoxGeometry(sx, hh, sz);
        }
      }
    }
    for(let i=props.length-1;i>=0;i--){
      const o = props[i];
      const kind = String(o?.userData?.kind||'');
      if(!syncedKinds.has(kind)) continue;
      if(keep.has(o)) continue;
      props.splice(i,1);
      try{ scene.remove(o); }catch(_){ }
    }
  }
  function snapshotWorld(){
    return {
      kind:'world',
      keys: (keys||[]).map(k=>({x:+k.position.x.toFixed(3), z:+k.position.z.toFixed(3)})),
      doorProg: Number(doorProg||0),
      cageLocked: !!cage?.userData?.locked,
      cageDoorOpen: !!cage?.userData?.doorOpen,
      cageAutoCloseT: +(cage?.userData?.autoCloseT || 0),
      releaseLeft: +(monsterReleaseLeft||0),
      sealUsed: !!doorState?.sealUsed,
      sealLeft: +(sealLeft||0),
      ts: Date.now()
    };
  }
  let lastAppliedWorldTs = 0;
  function applyWorld(w){
    if(!w || typeof w!=='object') return;
    const ts = Number(w.ts || 0);
    if(ts && ts < lastAppliedWorldTs) return;
    if(ts) lastAppliedWorldTs = ts;
    try{
      while(keys.length){ const k=keys.pop(); scene.remove(k); }
      (w.keys||[]).forEach(it=>spawnKeyAt(Number(it.x)||0, Number(it.z)||0));
      doorProg = Number(w.doorProg||0); q('pDoor').textContent = '문: '+doorProg+'/3';
      cage.userData.locked = !!w.cageLocked; cage.userData.doorOpen = !!w.cageDoorOpen; cage.userData.autoCloseT = Number(w.cageAutoCloseT||0);
      const lock = cage.getObjectByName('cageLock'); if(lock) lock.visible = !!cage.userData.locked;
      monsterReleaseLeft = Number(w.releaseLeft||0); if(monsterGate) monsterGate.visible = monsterReleaseLeft > 0.01;
      doorState.sealUsed = !!w.sealUsed; sealLeft = Number(w.sealLeft||0);
    }catch(_){ }
  }
  function appendChatLine(nick, text){
    try{ const line = (nick ? (nick+': ') : '') + String(text||''); addChat(line); }catch(_){ }
  }
  function sendState(force=false){
    if(!bridge.active || !bridge.sid) return;
    const snap = {
      x:+player.position.x.toFixed(3), y:+player.position.y.toFixed(3), z:+player.position.z.toFixed(3),
      yaw:+yaw.toFixed(4), hasKey:(keyCount>0), caught:Number(rabbitCaughtCount||0), ghost:!!rabbitGhost, trapped:!!player.userData.trapped,
      vx:+((player.userData&&player.userData.vx)||0).toFixed(3), vz:+((player.userData&&player.userData.vz)||0).toFixed(3),
      role: playerRole || 'rabbit' // [FIX] 역할 필드 추가 → 수신 측에서 아바타 올바르게 표시
    };
    const now = performance.now();
    const moving = Math.hypot(snap.vx||0, snap.vz||0) > 0.02;
    const changed = (
      bridgeStateCache.x === null ||
      Math.abs((bridgeStateCache.x||0) - snap.x) > (moving ? 0.025 : 0.05) ||
      Math.abs((bridgeStateCache.y||0) - snap.y) > 0.03 ||
      Math.abs((bridgeStateCache.z||0) - snap.z) > (moving ? 0.025 : 0.05) ||
      Math.abs((bridgeStateCache.yaw||0) - snap.yaw) > (moving ? 0.022 : 0.05) ||
      Math.abs((bridgeStateCache.vx||0) - snap.vx) > 0.04 ||
      Math.abs((bridgeStateCache.vz||0) - snap.vz) > 0.04 ||
      bridgeStateCache.hasKey !== snap.hasKey ||
      bridgeStateCache.caught !== snap.caught ||
      bridgeStateCache.ghost !== snap.ghost ||
      bridgeStateCache.trapped !== snap.trapped
    );
    const minGap = moving ? 16 : 80; // [FIX] 이동 중 전송 빈도 증가로 끊김 감소
    if(!force && !changed && (now - (bridgeStateCache.sentAt||0) < minGap)) return;
    Object.assign(bridgeStateCache, snap, { sentAt: now });
    relay('state', { seq:(++bridge.stateSeq), role:playerRole, seat:Number(bridge.selfSeat ?? -1), sentAt: Date.now(), ...snap });
  }

  function maybeSendWorld(force){
    if(!bridge.active || !bridge.sid) return;
    const now=performance.now();
    if(!force && now-bridge.lastWorldAt < 3200) return;
    bridge.lastWorldAt = now;
    const snap = snapshotWorld();
    if(bridge.isHost) relay('world', snap);
    else relay('world_req', {});
  }
  const _sendChat = sendChat;
  sendChat = function(){
    const msgText = String(chatIn.value||'').trim();
    if(!msgText) return false;
    const ok = _sendChat.apply(this, arguments);
    try{
      if(ok && bridge.active){
        relay('chat', { text:msgText });
      }
    }catch(_){ }
    return ok;
  };
  const _updatePanicMusic = (typeof window.updatePanicMusic === 'function' ? window.updatePanicMusic : (typeof updatePanicMusic === 'function' ? updatePanicMusic : null));
  if(_updatePanicMusic){ window.updatePanicMusic = function(dist){ if(playerRole==='monster') return; return _updatePanicMusic(dist); }; try{ updatePanicMusic = window.updatePanicMusic; }catch(_){ } }
  const _doInteract = (typeof window.doInteract === 'function' ? window.doInteract : (typeof doInteract === 'function' ? doInteract : null));
  if(_doInteract){ window.doInteract = function(){ const before = JSON.stringify(snapshotWorld()); const r = _doInteract.apply(this, arguments); setTimeout(()=>{ try{ if(JSON.stringify(snapshotWorld()) !== before) maybeSendWorld(true); }catch(_){ } }, 0); return r; }; try{ doInteract = window.doInteract; }catch(_){ } }
  if(!window.__BR3D_MESSAGE_HANDLER__){ window.__BR3D_MESSAGE_HANDLER__ = (e)=>{
    const d=e.data||{};
    if(!d || typeof d!=='object') return;
    if(d.type==='bridge_init'){
      setBridgeIdentity({
        sid: d.sessionId || d.mySid || window.__BR_BOOT_ID__ || bridge.sid || '',
        nick: d.nick || d.myNick || window.__BR_BOOT_NICK__ || bridge.nick || 'Player',
        roomId: d.roomCode || roomId || bridge.roomId,
        selfSeat: Number.isFinite(Number(d.selfSeat)) ? Number(d.selfSeat) : Number(d.seat),
        isHost: (typeof d.isHost === 'boolean') ? !!d.isHost : ((typeof d.host === 'boolean') ? !!d.host : bridge.isHost),
      });
      if (d.startPayload) applyBridgeStartPayload(d.startPayload);
      else if (pendingStartPayload) applyBridgeStartPayload(pendingStartPayload);
      post({ type:'bridge_ready', gameId:'backrooms3d' });
      if (bridge.start) { maybeSendWorld(true); sendState(true); }
      return;
    }
    if(d.type==='game_start'){
      const sp = d.payload || null;
      pendingStartPayload = sp || pendingStartPayload;
      if (applyBridgeStartPayload(sp)){
        pendingStartPayload = null;
        post({ type:'br_game_start_ack' });
        maybeSendWorld(true);
        sendState(true);
      }
      return;
    }
    if(d.type==='br_batch'){
      const list = Array.isArray(d.states) ? d.states : [];
      for (const item of list){
        try{ window.__BR3D_MESSAGE_HANDLER__({ data:{ type:'br_msg', msg:item } }); }catch(_){ }
      }
      return;
    }
    if(d.type==='br_msg'){
      const m=d.msg||{}; const kind=String(m.kind||m.t||''); const sid=String(m.from||m.sid||'');
      if(kind==='chat'){ if(sid!==bridge.sid) appendChatLine(m.nick||'Player', m.text||''); return; }
      if(kind==='state'){
        if(sid===bridge.sid) return;
        if(!sid) return;
        const msgSeat=Number(m.seat ?? -1);
        // bridge.start가 없어도 sid만으로 처리 (초기 연결 지연 해소)
        const roster = Array.isArray(bridge.start?.roster) ? bridge.start.roster : [];
        const rosterOk = !roster.length || roster.some(entry => String(entry?.sid||'') === sid);
        if (!rosterOk) return;
        const remoteKey = sid;
        // [FIX] state 메시지의 role 필드 우선 사용 (bridge.start 없어도 역할 처리)
        const msgRole = String(m.role || '');
        const role = (msgRole === 'monster' || msgRole === 'rabbit') ? msgRole :
                     (bridge.start ? resolveRoleForSid(bridge.start, sid, msgSeat, 'rabbit') : 'rabbit');
        if (role !== 'monster' && role !== 'rabbit') return;
        const r = ensureRemote(remoteKey, role);
        if(!r) return;
        const seq = Number(m.seq || 0);
        if(seq && seq <= Number(r.lastSeq || -1)) return;
        r.lastSeq = seq || (Number(r.lastSeq || 0) + 1);
        r.obj.visible = true;
        r.state = Object.assign({}, m, { role });
        r.targetX = Number(m.x)||0;
        r.targetY = Number(m.y)||0;
        r.targetZ = Number(m.z)||0;
        r.targetYaw = Number(m.yaw)||0;
        r.vx = Number(m.vx)||0;
        r.vz = Number(m.vz)||0;
        r.lastAt = performance.now();
        return;
      }
      if(kind==='world'){ if(!bridge.isHost && sid!==bridge.sid) applyWorld(m); return; }
      if(kind==='world_req'){ if(bridge.isHost && sid!==bridge.sid){ relay('world', snapshotWorld()); } return; }
      if(kind==='helper_state'){ if(!bridge.isHost && sid!==bridge.sid) applyHelperState(m); return; }
      if(kind==='caught'){ if(String(m.target||'')===bridge.sid){
          if (performance.now() < Number(bridge.ignoreCaughtUntil||0)) return;
          if(playerRole==='monster') return;
          rabbitCaughtCount = Number(rabbitCaughtCount||0) + 1;
          updateCaughtCloud();
          syncUiState();
          if(keyCount>0){ keyCount=0; q('pKey').textContent='🔑 0'; updateKeyIndicator(); placeKey(); }
          if(rabbitCaughtCount>=2){ makeRabbitGhost(); }
          else { trapRabbitInCage(6); }
          maybeSendWorld(true); sendState(true);
      } return; }
    }
  }; window.addEventListener('message', window.__BR3D_MESSAGE_HANDLER__); }
  const _animate = animate;
  animate = function(now){
    const bridgeNow = Number.isFinite(Number(now)) ? Number(now) : performance.now();
    const bridgeDt = Math.min(0.05, Math.max(0, (bridge.prevAnimateNow ? (bridgeNow - bridge.prevAnimateNow) / 1000 : 1/60)));
    bridge.prevAnimateNow = bridgeNow;
    if(bridge.start && (bridge.start.playerCount||0) >= 2){
      if (!bridge.spawnApplied && bridge.spawn){
        try{ player.userData.trapped = false; }catch(_){ }
        try{ rabbitGhost = false; rabbitCaughtCount = 0; updateCaughtCloud(); syncUiState(); }catch(_){ }
        player.position.set(Number(bridge.spawn.x)||0, Number(bridge.spawn.y)||0.05, Number(bridge.spawn.z)||0);
        yaw = Number.isFinite(Number(bridge.spawn.yaw)) ? Number(bridge.spawn.yaw) : yaw;
        player.rotation.y = yaw;
        if(monster) monster.rotation.y = yaw;
        bridge.spawnApplied = true;
      } else if (performance.now() < Number(bridge.forceSpawnUntil||0)) {
        try{ player.userData.trapped = false; }catch(_){ }
      }
      if(playerRole==='monster'){
        player.visible = false; ensureMonster(); monster.visible = true; monster.position.copy(player.position); monster.rotation.y = yaw;
      } else {
        player.visible = true;
        setAvatarGhostVisual(player, !!rabbitGhost, 0.38);
        if(monster) monster.visible = false;
      }
      for (const [sid,r] of bridge.remotes.entries()){
        const st=r.state;
        if(!st){ if(r.obj) r.obj.visible=false; continue; }
        if(playerRole==='monster' && !!st.ghost){ r.obj.visible=false; continue; }
        r.obj.visible=true;
        setAvatarGhostVisual(r.obj, !!st.ghost, 0.38);
        // [FIX] 부드러운 위치 보간: 패킷 간격 기반 예측 + 완만한 lerp
        const packetAge = Math.min(0.120, Math.max(0.016, (performance.now() - Number(r.lastAt||performance.now()))/1000));
        const predX = (Number(r.targetX ?? st.x) || 0) + (Number(r.vx)||0) * packetAge;
        const predY = Number(r.targetY ?? st.y) || 0;
        const predZ = (Number(r.targetZ ?? st.z) || 0) + (Number(r.vz)||0) * packetAge;
        // 거리가 너무 멀면(3m+) 빠르게 따라가고, 가까우면 부드럽게 보간
        const snapDist = Math.hypot(predX - r.obj.position.x, predZ - r.obj.position.z);
        const lerpSpeed = snapDist > 3.0 ? 22.0 : (snapDist > 1.2 ? 12.0 : 8.0);
        const lerpA = 1 - Math.exp(-bridgeDt * lerpSpeed);
        r.obj.position.x += (predX - r.obj.position.x) * lerpA;
        r.obj.position.y += (predY - r.obj.position.y) * lerpA;
        r.obj.position.z += (predZ - r.obj.position.z) * lerpA;
        const targetYaw = Number(r.targetYaw ?? st.yaw) || 0;
        let yawDiff = targetYaw - r.obj.rotation.y;
        while(yawDiff > Math.PI) yawDiff -= Math.PI*2;
        while(yawDiff < -Math.PI) yawDiff += Math.PI*2;
        r.obj.rotation.y += yawDiff * Math.min(1, lerpA * 1.4);
        if(r.role!=='monster'){ const ki=r.obj.getObjectByName('remoteKey'); if(ki) ki.visible=(!st.ghost && !!st.hasKey); const cc=r.obj.getObjectByName('remoteCaught'); if(cc) cc.visible = (!st.ghost && Number(st.caught||0)===1); }
      }
      const nowp=performance.now();
      if(nowp - bridge.lastStateAt > 25){ bridge.lastStateAt = nowp; sendState(false); }
      if(bridge.isHost){
        if(nowp - bridge.lastCatchAt > 170){
          bridge.lastCatchAt = nowp;
          const hunters = [];
          if(playerRole==='monster') hunters.push({ sid:bridge.sid, x:player.position.x, z:player.position.z });
          else for(const [sid,r] of bridge.remotes.entries()){ if(r.role==='monster' && r.state){ hunters.push({ sid, x:Number(r.state.x)||0, z:Number(r.state.z)||0 }); break; } }
          if(hunters.length){
            if (Number(monsterReleaseLeft||0) > 0.01) return _animate(now);
            if (performance.now() < Number(bridge.ignoreCaughtUntil||0)) return _animate(now);
            const rabbits=[];
            if(playerRole!=='monster' && !rabbitGhost && !player.userData.trapped) rabbits.push({ sid:bridge.sid, x:player.position.x, z:player.position.z, caught:rabbitCaughtCount, trapped:!!player.userData.trapped });
            for(const [sid,r] of bridge.remotes.entries()){ if(r.role!=='monster' && r.state && !r.state.ghost && !r.state.trapped) rabbits.push({ sid, x:Number(r.state.x)||0, z:Number(r.state.z)||0, caught:Number(r.state.caught||0), trapped:!!r.state.trapped }); }
            outer: for(const hunter of hunters){
              for(const rb of rabbits){
                if(rb.sid===hunter.sid || rb.trapped) continue;
                const dx=rb.x-hunter.x, dz=rb.z-hunter.z;
                if(dx*dx+dz*dz < 2.1*2.1){ relay('caught', { target: rb.sid }); break outer; }
              }
            }
          }
        }
      }
    }
    return _animate(now);
  };
  setTimeout(()=>{
    post({ type:'bridge_ready', gameId:'backrooms3d' });
  }, 0);

  // Kick the render/update loop exactly once after all wrappers are installed.
  try{ if(!window.__BR3D_RAF_ID__) window.__BR3D_RAF_ID__ = requestAnimationFrame(animate); }catch(_){ requestAnimationFrame(animate); }

}

(function boot(){
  const deadline=Date.now()+2500;
  function step(){
    if(typeof THREE!=="undefined"){
      try{ run3D(); $("pMode").textContent="🎮 3D"; return; }
      catch(e){ console.error(e); cleanup3D(); showFallback("3D 초기화 오류: "+(e.message||e)); return; }
    }
    if(Date.now()>deadline){ showFallback("three.js 로드가 지연/차단되었습니다. 2D로 테스트하세요."); return; }
    setSub("three.js 로드 중…");
    setTimeout(step,80);
  }
  step();
})();
</script>

<script>
// bridge moved into run3D
</script>

</body>
</html>