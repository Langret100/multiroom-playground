  addEventListener("keyup",(e)=>{ if(e.key==="Shift") shiftHeld=false; });

  // Mobile/PC E button behavior: if prompt is visible (interactable), E triggers interact; otherwise it acts as sprint while held.
  const btnE = $("btnE");
